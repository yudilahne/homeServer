APP_NAME="Yudilahne App"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.yudilahne.my.id
APP_TIMEZONE=Asia/Makassar
FRONTEND_URL=https://app.yudilahne.my.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=yudilahne_app
DB_USERNAME=yudilahne
DB_PASSWORD=change-this-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.yudilahne.my.id
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=app.yudilahne.my.id,localhost,127.0.0.1,localhost:3000,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_TOKEN_PREFIX=yhs_

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@yudilahne.my.id"
MAIL_FROM_NAME="${APP_NAME}"

FILAMENT_ADMIN_EMAILS=admin@yudilahne.my.id

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

RUN_DB_SEED=true
ADMIN_NAME="Yudilahne Admin"
ADMIN_EMAIL=admin@yudilahne.my.id
ADMIN_PASSWORD=change-this-admin-password

VITE_APP_NAME="${APP_NAME}"
